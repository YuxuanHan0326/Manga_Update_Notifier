# Database / runtime
MUP_DATABASE_URL=sqlite:///./data/app.db
MUP_APP_BASE_URL=http://localhost:8000

# Scheduler defaults
MUP_APP_TIMEZONE=Asia/Shanghai
MUP_TIMEZONE_AUTO=true
MUP_CHECK_CRON=0 */6 * * *
MUP_DAILY_SUMMARY_CRON=0 21 * * *

# Timezone auto-detect
MUP_IP_TIMEZONE_API_URL_TEMPLATE=https://ipapi.co/{ip}/json/
MUP_IP_TIMEZONE_SELF_API_URL=https://ipapi.co/json/
MUP_IP_TIMEZONE_TIMEOUT_SEC=5.0

# Notifications
MUP_WEBHOOK_ENABLED=false
MUP_WEBHOOK_URL=
MUP_RSS_ENABLED=true

# Source adapters
MUP_CM_API_BASE_URL=https://api.mangacopy.com
MUP_KXO_BASE_URL=https://kzo.moe
MUP_KXO_AUTH_MODE=guest
MUP_KXO_COOKIE=
MUP_KXO_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/123.0.0.0 Safari/537.36
MUP_KXO_REMEMBER_SESSION=false
